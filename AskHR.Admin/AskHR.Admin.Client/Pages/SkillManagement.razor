@page "/skills"
@using AskHR.Common.Dtos.Agents
@using AskHR.Admin.Client.Services
@attribute [Authorize(Roles = "Admin")]
@rendermode @(new InteractiveWebAssemblyRenderMode(prerender: false))
@inject NavigationManager Navigation
@inject SkillClient SkillClient

<PageTitle>Skill Management</PageTitle>

<div class="container-fluid px-2 px-md-4 py-2 py-md-3">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0">
                <i class="bi bi-tools me-2"></i>Skill Management
            </h2>
            <button class="btn btn-primary" @onclick="CreateNewSkill">
                <i class="bi bi-plus-circle me-2"></i>New Skill
            </button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (skills != null)
    {
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Skill ID</th>
                                <th>Name</th>
                                <th>Owner</th>
                                <th>Provider/Model</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var skill in skills)
                            {
                                <tr>
                                    <td><code>@skill.SkillId</code></td>
                                    <td>@skill.Name</td>
                                    <td>@skill.Owner</td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(skill.PrimaryProvider))
                                        {
                                            <span class="badge bg-info">@skill.PrimaryProvider / @skill.PrimaryModel</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">Default</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge @(skill.Enabled ? "bg-success" : "bg-danger")">
                                            @(skill.Enabled ? "Enabled" : "Disabled")
                                        </span>
                                    </td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-outline-primary me-2" @onclick="() => EditSkill(skill)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSkill(skill.Id)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@if (showEditor && currentSkill != null)
{
    <SkillConfigEditor Skill="currentSkill"
                       Title="@(isEditing ? "Edit Skill" : "New Skill")"
                       OnSave="SaveSkill"
                       OnCancel="CloseEditor" />
}

@code {
    private bool isLoading = true;
    private List<SkillDto>? skills;
    private bool showEditor = false;
    private bool isEditing = false;
    private SkillDto? currentSkill;

    protected override async Task OnInitializedAsync()
    {
        await LoadSkills();
    }

    private async Task LoadSkills()
    {
        isLoading = true;
        skills = await SkillClient.GetSkillsAsync();
        isLoading = false;
    }

    private void CreateNewSkill()
    {
        currentSkill = new SkillDto
        {
            Scope = new(),
            AnswerPolicy = new(),
            Escalation = new()
        };
        isEditing = false;
        showEditor = true;
    }

    private void EditSkill(SkillDto skill)
    {
        currentSkill = new SkillDto
        {
            Id = skill.Id,
            SkillId = skill.SkillId,
            Name = skill.Name,
            Description = skill.Description,
            Instructions = skill.Instructions,
            PrimaryProvider = skill.PrimaryProvider,
            PrimaryModel = skill.PrimaryModel,
            Owner = skill.Owner,
            Enabled = skill.Enabled,
            ApprovalStatus = skill.ApprovalStatus,
            Version = skill.Version,
            Tools = skill.Tools is null ? [] : [.. skill.Tools],
            Attachments = skill.Attachments is null ? [] : [.. skill.Attachments],
            Scope = CloneScope(skill.Scope),
            AnswerPolicy = CloneAnswerPolicy(skill.AnswerPolicy),
            Escalation = CloneEscalation(skill.Escalation)
        };
        isEditing = true;
        showEditor = true;
    }

    private async Task SaveSkill(SkillDto skill)
    {
        currentSkill = skill;

        if (isEditing)
        {
            await SkillClient.UpdateSkillAsync(currentSkill.Id, currentSkill);
        }
        else
        {
            await SkillClient.CreateSkillAsync(currentSkill);
        }

        showEditor = false;
        await LoadSkills();
    }

    private async Task DeleteSkill(Guid id)
    {
        await SkillClient.DeleteSkillAsync(id);
        await LoadSkills();
    }

    private void CloseEditor()
    {
        showEditor = false;
    }

    private static SkillScopeDto CloneScope(SkillScopeDto? scope)
        => scope is null
            ? new()
            : new SkillScopeDto
            {
                Topics = scope.Topics is null ? [] : [.. scope.Topics],
                Tags = scope.Tags is null ? [] : [.. scope.Tags],
                BusinessUnits = scope.BusinessUnits is null ? [] : [.. scope.BusinessUnits]
            };

    private static SkillAnswerPolicyDto CloneAnswerPolicy(SkillAnswerPolicyDto? policy)
        => policy is null
            ? new()
            : new SkillAnswerPolicyDto
            {
                RequireCitation = policy.RequireCitation,
                RefuseIfExpired = policy.RefuseIfExpired,
                ClarifyingQuestions = policy.ClarifyingQuestions is null ? [] : [.. policy.ClarifyingQuestions]
            };

    private static SkillEscalationDto CloneEscalation(SkillEscalationDto? escalation)
        => escalation is null
            ? new()
            : new SkillEscalationDto
            {
                FallbackContact = escalation.FallbackContact,
                SeverityHint = escalation.SeverityHint
            };
}
